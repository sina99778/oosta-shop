# Production environment. Copy to .env.production and fill in real values.
#   docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# Public origin (scheme + host, NO trailing slash). Used for CORS, the Zarinpal
# return URL (WEB_BASE_URL), and to derive NEXT_PUBLIC_API_URL (= $PUBLIC_ORIGIN/api).
PUBLIC_ORIGIN=https://your-domain.com

# Postgres
POSTGRES_USER=oosta
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=oosta

# Auth (REQUIRED in production — the API refuses to boot with the dev default)
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Payments — set to "zarinpal" with a real merchant id for live payments,
# or "mock" to run without a gateway.
PAYMENT_PROVIDER=zarinpal
ZARINPAL_MERCHANT_ID=your-zarinpal-merchant-id
ZARINPAL_SANDBOX=false
ZARINPAL_CURRENCY=IRR

# Manual card-to-card payment (buyer transfers money, uploads a receipt, admin approves).
# Set CARD_TO_CARD_ENABLED=true and fill the destination card shown to buyers.
CARD_TO_CARD_ENABLED=false
CARD_NUMBER=
CARD_HOLDER=
CARD_BANK=

# AI SEO assistant (Google Gemini). Optional — analyzer works without it.
# Get a key at https://aistudio.google.com/apikey
# Model id: gemini-3.5-flash (recommended) · gemini-3.1-pro (smartest) · gemini-3.1-flash-lite (cheapest)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
# Tried automatically if the primary model is overloaded (503). Leave as-is or empty to disable.
GEMINI_FALLBACK_MODEL=gemini-2.5-flash

# OpenRouter (openrouter.ai) — preferred provider for the Telegram AI agent when set
# (one key unlocks every frontier model + image generation). Get a key at
# https://openrouter.ai/settings/keys
# Text model: anthropic/claude-sonnet-4.6 (best agent quality) · google/gemini-3.5-flash (cheaper)
# Image model: google/gemini-2.5-flash-image (~$0.04/image) · google/gemini-3.1-flash-image-preview (better)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_FALLBACK_MODEL=google/gemini-3.5-flash
OPENROUTER_IMAGE_MODEL=google/gemini-2.5-flash-image

# Telegram admin bot (optional — leave both blank to disable).
# Token from @BotFather; admin id (your numeric Telegram user id) from @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# Automatic Telegram DB backups: send a dump every N hours (0 disables). Default 24.
BACKUP_INTERVAL_HOURS=24
