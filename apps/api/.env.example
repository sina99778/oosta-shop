# Copy this file to apps/api/.env and fill in real values for local development.

NODE_ENV="development"
API_PORT="4000"
CORS_ORIGIN="http://localhost:3000"
WEB_BASE_URL="http://localhost:3000"

DATABASE_URL="postgresql://oosta:oosta@localhost:5432/oosta?schema=public"

JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS="12"

# Payment gateway: "mock" (default, no gateway) or "zarinpal".
PAYMENT_PROVIDER="mock"
ZARINPAL_MERCHANT_ID="00000000-0000-0000-0000-000000000000"
ZARINPAL_SANDBOX="true"
ZARINPAL_CURRENCY="IRR"

# Manual card-to-card payment (buyer transfers money, uploads a receipt, admin approves).
CARD_TO_CARD_ENABLED="false"
CARD_NUMBER=""
CARD_HOLDER=""
CARD_BANK=""

# AI SEO assistant (Google Gemini) — optional.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_FALLBACK_MODEL="gemini-2.5-flash"

# OpenRouter — preferred provider for the Telegram AI agent when set (optional).
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="openai/gpt-5.5"
OPENROUTER_FALLBACK_MODEL="google/gemini-3.1-pro-preview"
OPENROUTER_IMAGE_MODEL="google/gemini-3-pro-image-preview"

# Telegram admin bot (optional — leave blank to disable).
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ADMIN_ID=""

# Automatic Telegram DB backups every N hours (0 disables).
BACKUP_INTERVAL_HOURS="24"
