// Prisma schema for the oostaAI digital products platform.
// Payment fields are intentionally gateway-agnostic (Zarinpal / Stripe / manual)
// so the Phase 5 payment integration requires no schema change.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Enums ────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum ProductType {
  ACCOUNT
  LICENSE
  GIFTCARD
}

enum InventoryStatus {
  AVAILABLE
  RESERVED
  SOLD
}

enum PaymentStatus {
  PENDING
  PENDING_REVIEW
  PAID
  FAILED
  REJECTED
  REFUNDED
  EXPIRED
}

enum PaymentProvider {
  ZARINPAL
  STRIPE
  MANUAL
  CARD_TO_CARD
}

enum ReceiptStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketStatus {
  OPEN
  ANSWERED
  CLOSED
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

// ── Models ───────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  phone        String?  @unique
  passwordHash String
  role           Role            @default(USER)
  orders         Order[]
  reviews        Review[]
  tickets        Ticket[]
  ticketMessages TicketMessage[]
  apiKeys        ApiKey[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@map("users")
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id               String  @id @default(cuid())
  name             String
  slug             String  @unique
  // Short tagline shown near the price; description is the long (Markdown) body.
  shortDescription String?
  description      String
  // Structured key/value spec rows, e.g. [{ "label": "Warranty", "value": "30 days" }]
  specs            Json?
  isFeatured       Boolean @default(false)
  // Manual ordering on listing pages (higher comes first; ties fall back to newest).
  sortOrder        Int     @default(0)
  // SEO overrides (fall back to name / shortDescription when empty)
  metaTitle        String?
  metaDescription  String?
  image            String?
  // Primary image stored in the DB (so it is included in backups). imageMimeType
  // is kept light for listings; imageData is only selected by the image endpoint.
  // Additional gallery images live in ProductImage.
  imageData     Bytes?
  imageMimeType String?
  type        ProductType
  isActive    Boolean         @default(true)
  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  plans       ProductPlan[]
  inventory   InventoryItem[]
  orderItems  OrderItem[]
  images      ProductImage[]
  reviews     Review[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([categoryId])
  @@index([isFeatured])
  @@map("products")
}

// Additional gallery images for a product (the primary image stays on Product).
model ProductImage {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageData Bytes
  mimeType  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

// Customer rating + review. Submitted PENDING; shown only once an admin APPROVES.
model Review {
  id        String       @id @default(cuid())
  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating    Int // 1..5
  comment   String?
  status    ReviewStatus @default(PENDING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([productId, userId])
  @@index([productId, status])
  @@map("reviews")
}

// Customer support tickets with a threaded message log.
model Ticket {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  status    TicketStatus    @default(OPEN)
  messages  TicketMessage[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@map("tickets")
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  isStaff   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}

// API key for programmatic admin access (e.g. an external AI assistant). Only the
// SHA-256 hash is stored; the raw key is shown once at creation.
model ApiKey {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  prefix     String // first chars, for display only
  keyHash    String    @unique
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("api_keys")
}

// Blog / educational content. Body is Markdown (supports inline images + video
// embeds). Cover image bytes live in the DB so they are part of backups.
model BlogPost {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  excerpt     String?
  content     String // Markdown
  coverData   Bytes?
  coverMime   String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status, publishedAt])
  @@map("blog_posts")
}

// Standalone CMS page (e.g. "about-us", "terms") served at /p/<slug> on the web.
// Body is Markdown (same renderer as blog posts). Editable by admins and the AI agent.
model Page {
  id        String     @id @default(cuid())
  slug      String     @unique
  title     String
  content   String // Markdown
  status    PostStatus @default(PUBLISHED)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status])
  @@map("pages")
}

// Site-wide key/value settings (theme colors, hero text, announcement bar).
// Keys are constrained by the Zod schema in settings.schemas.ts — not free-form.
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// One storefront page view (first-party analytics; no cookies). visitorHash is
// sha256(ip|user-agent|utc-day), so uniques are per-day and IPs are never stored.
model Visit {
  id          String   @id @default(cuid())
  path        String
  country     String   @default("??") // ISO 3166-1 alpha-2 from the CDN header
  visitorHash String
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([country, createdAt])
  @@map("visits")
}

// Small named binary assets (e.g. the Enamad e-trust badge image in the footer).
model SiteAsset {
  key       String   @id
  imageData Bytes
  mimeType  String
  updatedAt DateTime @updatedAt

  @@map("site_assets")
}

// Uploaded media (images) referenced by URL inside blog post Markdown.
model BlogMedia {
  id        String   @id @default(cuid())
  imageData Bytes
  mimeType  String
  createdAt DateTime @default(now())

  @@map("blog_media")
}

// A purchasable "time-plan" / variant of a product (the price lives here).
model ProductPlan {
  id           String          @id @default(cuid())
  productId    String
  product      Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  label        String // e.g. "1 Month", "3 Months", "Lifetime"
  durationDays Int? // null = perpetual (license / gift card)
  price        Decimal         @db.Decimal(12, 2)
  salePrice    Decimal?        @db.Decimal(12, 2) // discounted price (when set & < price)
  currency     String          @default("IRR")
  isActive     Boolean         @default(true)
  inventory    InventoryItem[]
  orderItems   OrderItem[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([productId])
  @@map("product_plans")
}

// A single deliverable unit of stock. The flexible credential payload holds
// whichever fields are relevant to `type` (account, license, or gift card).
model InventoryItem {
  id     String          @id @default(cuid())
  type   ProductType
  status InventoryStatus @default(AVAILABLE)

  productId String
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  planId    String?
  plan      ProductPlan? @relation(fields: [planId], references: [id])

  // Credential payload (only the fields matching `type` are populated)
  accountEmail    String?
  accountPassword String?
  licenseKey      String?
  giftCardCode    String?

  // Fulfillment linkage — set atomically when the owning order is paid
  orderItemId String?
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
  soldAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId, planId, status])
  @@index([status])
  @@index([orderItemId])
  @@map("inventory_items")
}

model Order {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  items         OrderItem[]
  totalAmount   Decimal       @db.Decimal(12, 2)
  currency      String        @default("IRR")
  paymentStatus PaymentStatus @default(PENDING)

  // Gateway-agnostic payment references:
  //   paymentAuthority = pre-payment token  (Stripe session id / Zarinpal Authority)
  //   paymentRefId     = post-verify ref     (Stripe payment_intent / Zarinpal RefID)
  paymentProvider  PaymentProvider?
  paymentAuthority String?          @unique
  paymentRefId     String?

  receipts  Receipt[]

  paidAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@index([paymentStatus])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  planId    String
  plan      ProductPlan @relation(fields: [planId], references: [id])

  quantity  Int     @default(1)
  unitPrice Decimal @db.Decimal(12, 2)
  lineTotal Decimal @db.Decimal(12, 2)

  // Inventory units assigned to fulfill this line (one per quantity)
  fulfilledItems InventoryItem[]

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_items")
}

// Card-to-card payment receipts. Stored permanently (image bytes live in the DB,
// so backups include them) — receipts are NEVER deleted, even after approval, so
// the admin always keeps a full, auditable history.
model Receipt {
  id           String        @id @default(cuid())
  orderId      String
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  imageData    Bytes
  mimeType     String
  reference    String?
  status       ReceiptStatus @default(PENDING)
  reviewerNote String?
  reviewedAt   DateTime?
  createdAt    DateTime      @default(now())

  @@index([status])
  @@index([orderId])
  @@map("receipts")
}
