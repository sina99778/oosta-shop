# =====================================================================
# Project-wide environment variable contract (reference).
# Copy the relevant sections into apps/api/.env and apps/web/.env.local.
# Never commit real secrets — only this .example file is tracked.
# =====================================================================

# ── Database (Postgres) ──────────────────────────────────────────────
# Matches the credentials in docker-compose.yml for local development.
DATABASE_URL="postgresql://oosta:oosta@localhost:5432/oosta?schema=public"

# ── API server ───────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT="4000"
# Comma-separated list of browser origins allowed by CORS (the web app).
CORS_ORIGIN="http://localhost:3000"

# ── Authentication (JWT + bcrypt) ────────────────────────────────────
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="7d"
BCRYPT_SALT_ROUNDS="12"

# ── Stripe (payments + instant delivery webhook) ─────────────────────
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
CHECKOUT_SUCCESS_URL="http://localhost:3000/checkout/success?session_id={CHECKOUT_SESSION_ID}"
CHECKOUT_CANCEL_URL="http://localhost:3000/checkout/cancel"

# ── Web app (client-side, must be NEXT_PUBLIC_*) ─────────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
