{
  "name": "oostaai",
  "version": "0.0.0",
  "private": true,
  "description": "Digital products sales platform (AI accounts, licenses, gift cards) with automatic instant delivery",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint . && npm run lint -w @oosta/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev:api": "npm run dev -w @oosta/api",
    "dev:web": "npm run dev -w @oosta/web",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:local:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pg-local.ps1 start",
    "db:local:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pg-local.ps1 stop",
    "db:local:status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pg-local.ps1 status"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  }
}
